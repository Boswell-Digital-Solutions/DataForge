# VibeForge Backend Environment Variables

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=true

# Database (future - currently JSON file-based)
# DATABASE_URL=postgresql://user:password@localhost/vibeforge
# VECTOR_DB_URL=http://localhost:6333  # Qdrant or similar

# Model providers (for future integration)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://localhost:8000"]
