# DataForge Configuration Template
# Copy this file to .env and fill in the values for your environment
# IMPORTANT: .env should NEVER be committed to version control

# ============================================
# Database Configuration
# ============================================
# PostgreSQL database connection details (when using Docker Compose)
POSTGRES_DB=dataforge
POSTGRES_USER=postgres
# REQUIRED: Set to a secure random password in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=<CHANGE_ME_PRODUCTION_PASSWORD>
POSTGRES_PORT=5432

# Full database URL (usually auto-constructed, but can override)
# DATAFORGE_DATABASE_URL=postgresql://postgres:<PASSWORD>@localhost:5432/dataforge

# ============================================
# Canonical ForgeEvent.v1 Ingress
# ============================================
# Fail closed until migration 20260723_01 is applied and every producer key
# is bound to service_name, environment, tenant_ref, and telemetry:write.
DATAFORGE_FORGE_EVENT_V1_WRITE_ENABLED=false
# Separate PostgreSQL login on the same database. It must inherit only the
# migration-owned dataforge_telemetry_ingest NOLOGIN role and must differ from
# the business-pool user. No fallback to DATAFORGE_DATABASE_URL is permitted.
DATAFORGE_TELEMETRY_DATABASE_URL=
DATAFORGE_TELEMETRY_DB_POOL_SIZE=2
DATAFORGE_TELEMETRY_DB_MAX_OVERFLOW=0
DATAFORGE_TELEMETRY_DB_POOL_TIMEOUT_SECONDS=2
DATAFORGE_TELEMETRY_DB_POOL_RECYCLE_SECONDS=300
DATAFORGE_TELEMETRY_DB_CONNECT_TIMEOUT_SECONDS=3
DATAFORGE_TELEMETRY_DB_STATEMENT_TIMEOUT_MS=2000
DATAFORGE_TELEMETRY_DB_LOCK_TIMEOUT_MS=500
DATAFORGE_TELEMETRY_DB_IDLE_IN_TX_TIMEOUT_MS=5000
DATAFORGE_TELEMETRY_INGEST_RATE_PER_SECOND=20
DATAFORGE_TELEMETRY_INGEST_RATE_BURST=40

# DataForge's own producer uses the same authenticated canonical HTTP boundary.
# Provision a telemetry:write key bound to service=dataforge, exact ENVIRONMENT,
# and tenant_ref=null. Keep unset until migration + writer enablement are proved.
DATAFORGE_TELEMETRY_BASE_URL=http://127.0.0.1:8000
DATAFORGE_TELEMETRY_API_KEY=
DATAFORGE_TELEMETRY_TIMEOUT=5
# CP2 bounded-recovery pilot (opt in). The immediate parent must be owned by
# the DataForge OS user with mode 0700; the SQLite file is created mode 0600.
# Keep one unique spool path per producer process.
DATAFORGE_TELEMETRY_SPOOL_PATH=
DATAFORGE_TELEMETRY_DRAIN_INTERVAL_SECONDS=5
DATAFORGE_TELEMETRY_DRAIN_TIMEOUT_SECONDS=15

# ============================================
# Caching Configuration (Optional but Recommended)
# ============================================
# Redis URL for distributed caching and performance optimization
# If not set, caching will be disabled (application still works, just slower)
# Format: redis://[username:password@]localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ============================================
# Security Configuration - CRITICAL
# ============================================
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This MUST be a strong, random value in production
SECRET_KEY=your-secret-key-here-change-in-production

# JWT configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin token for API key rotation and secrets sync from Forge_Command
# This MUST match the token configured in Forge_Command to enable cloud sync
ROTATION_ADMIN_TOKEN=forge-admin-token-2024-secure

# Emergency operations key (for break-glass scenarios)
# EMERGENCY_OPS_KEY=your-emergency-key-here

# Required for database-backed API key hashing, including the dedicated
# AuthorForge analytics writer key. Its key metadata must be exactly scoped
# with service=authorforge and scopes=["analytics:write"].
# API_KEY_SALT=generate-a-long-random-value

# Encryption key for LLM provider secrets (Fernet-compatible)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRETS_ENCRYPTION_KEY=your-secrets-encryption-key-here

# ============================================
# Embedding Provider (Choose ONE)
# ============================================
# Recommended: Voyage AI (Anthropic-owned)
VOYAGE_API_KEY=your-voyage-api-key

# Alternative: OpenAI
# OPENAI_API_KEY=your-openai-api-key

# Alternative: Cohere
# COHERE_API_KEY=your-cohere-api-key

# Anthropic API Key (for future use with Claude API)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================
# Embedding Configuration (Ecosystem-Wide)
# ============================================
# Shared embedding vector dimension across all Forge services
# Default: 1536 (text-embedding-3-small). Set consistently across services.
FORGE_EMBED_DIM=1536

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8001

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ============================================
# Supabase Log Ingestion (scheduled pull → durable evidence)
# ============================================
# Only the scheduled poller (scripts/poll_supabase_logs.py) needs these; the
# web service does not. Leave blank to run the poller in --input-file mode only.
# Management API token: https://supabase.com/dashboard/account/tokens
# SUPABASE_PROJECT_REF=your-project-ref
# SUPABASE_ACCESS_TOKEN=sbp_your_management_api_token
# SUPABASE_LOG_SOURCE_TABLE=edge_logs
# Salt for one-way hashing of auth_user; if blank, identities are dropped (not hashed).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# SUPABASE_LOG_IDENTITY_SALT=your-random-salt
# SUPABASE_LOG_POLL_LOOKBACK_SECONDS=900
# SUPABASE_LOG_POLL_OVERLAP_SECONDS=120
# SUPABASE_LOG_POLL_MAX_ROWS=1000

# ============================================
# Render private-dependency build authentication
# ============================================
# Build-only fine-grained GitHub token with Contents:Read on forge-telemetry and
# forge_contract_core. This is token auth; SSH_KEY/SSH_KEY_B64 are not consumed.
# FORGE_TELEMETRY_TOKEN=github_pat_read_only

# ============================================
# AuthorForge data boundary
# ============================================
# AuthorForge manuscripts, notes, prompts, responses, research, worldbuilding,
# attachments, embeddings, paths, and identity stay in AuthorForge's embedded
# database. DataForge accepts only AuthorForgeAnalyticsEnvelope.v1 at the
# dedicated scoped endpoint; there is no content-sync configuration.

# ============================================
# Security Best Practices
# ============================================
# For DEVELOPMENT:
#   - Use values above with localhost settings
#   - .env file kept in .gitignore (never committed)
#
# For PRODUCTION:
#   - Use strong, randomly-generated SECRET_KEY
#   - Set specific ALLOWED_ORIGINS (not localhost)
#   - Use external PostgreSQL instance (managed database)
#   - Store secrets in secure vault (AWS Secrets Manager, HashiCorp Vault, etc.)
#   - Enable HTTPS/TLS for all connections
#   - Use strong database passwords
#   - Rotate API keys regularly
#   - Set up monitoring and logging
