# DataForge Production Environment Configuration
# SECURITY: Never commit actual secrets to version control
# Use: docker-compose config --resolve-image-digests or similar for secret injection

# Application Settings
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=false

# Security
SECRET_KEY=your-production-secret-key-min-32-chars-strongly-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=dataforge
DATABASE_USER=postgres
DATABASE_PASSWORD=your-secure-postgres-password-change-this
# Format: postgresql://user:password@host:port/database
DATAFORGE_DATABASE_URL=postgresql://postgres:${DATABASE_PASSWORD}@postgres:5432/dataforge

# Database Connection Pool
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_PRE_PING=true

# Redis Configuration
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-secure-redis-password-change-this
REDIS_DB=0
# Format: redis://password@host:port/db
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Redis Connection Pool
REDIS_POOL_SIZE=20
REDIS_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=true

# Embedding Configuration (Choose primary provider)
EMBEDDING_PROVIDER=voyage  # Options: voyage, openai, cohere
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSION=1024

# Voyage AI Configuration
VOYAGE_API_KEY=your-voyage-api-key-here
VOYAGE_MODEL=voyage-3

# OpenAI Configuration (alternative provider)
# SECURITY: Set via environment variable injection, never commit actual keys
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSION=3072

# Cohere Configuration (alternative provider)
COHERE_API_KEY=your-cohere-api-key-here
COHERE_EMBEDDING_MODEL=embed-english-v3.0

# Authentication Settings
AUTH_ALGORITHM=HS256
AUTH_SECRET_KEY=${SECRET_KEY}

# CORS Configuration
ALLOWED_ORIGINS=https://example.com,https://www.example.com,https://api.example.com
ALLOWED_CREDENTIALS=true
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# API Configuration
API_TITLE=DataForge API
API_VERSION=1.0.0
API_DESCRIPTION=Enterprise Due Diligence Platform API
API_DOCS_URL=/docs
API_OPENAPI_URL=/openapi.json

# Admin User (create on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-initial-password-change-immediately

# Feature Flags
ENABLE_SWAGGER_DOCS=false  # Disable in production for security
ENABLE_REDOC_DOCS=false
ENABLE_OPENAPI_URL=false
ENABLE_AUTO_INDEXES=true
ENABLE_CACHE_WARMING=true

# Performance Settings
QUERY_TIMEOUT=30  # seconds
EMBEDDING_BATCH_SIZE=100
EMBEDDING_CACHE_TTL=3600  # seconds (1 hour)
SEARCH_CACHE_TTL=300  # seconds (5 minutes)
PROJECT_CACHE_TTL=300  # seconds (5 minutes)

# Health Check Settings
HEALTH_CHECK_INTERVAL=30  # seconds
HEALTH_CHECK_TIMEOUT=5  # seconds
DATABASE_HEALTH_ENABLED=true
REDIS_HEALTH_ENABLED=true
EMBEDDING_SERVICE_HEALTH_ENABLED=true

# Logging Configuration
LOG_FORMAT=json  # Options: json, text
LOG_TO_FILE=true
LOG_FILE_PATH=/var/log/dataforge/app.log
LOG_MAX_BYTES=104857600  # 100MB
LOG_BACKUP_COUNT=10
LOG_LEVEL_APP=INFO
LOG_LEVEL_DATABASE=WARNING
LOG_LEVEL_EMBEDDING=INFO

# Monitoring and Metrics
METRICS_ENABLED=true
METRICS_PORT=8001
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true

# Sentry Error Tracking (optional)
SENTRY_ENABLED=false
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Email Notifications (optional)
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=noreply@example.com
EMAIL_SMTP_PASSWORD=your-email-password
EMAIL_FROM_ADDRESS=DataForge <noreply@example.com>

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC
BACKUP_RETENTION_DAYS=30

# Security Headers
ENABLE_SECURITY_HEADERS=true
HSTS_MAX_AGE=31536000  # 1 year
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false  # Only enable after verified

# SSL/TLS Configuration (for internal communication)
SSL_ENABLED=false  # Nginx handles TLS termination
SSL_CERT_PATH=/etc/nginx/certs/server.crt
SSL_KEY_PATH=/etc/nginx/certs/server.key

# Nginx Configuration
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=4096
NGINX_KEEPALIVE_TIMEOUT=65
NGINX_GZIP=on
NGINX_GZIP_LEVEL=6

# Pod/Container Specific
ENVIRONMENT_REGION=us-east-1
ENVIRONMENT_ZONE=us-east-1a
ENVIRONMENT_INSTANCE_ID=dataforge-prod-001
POD_NAME=dataforge-api-0
POD_NAMESPACE=default
POD_IP=127.0.0.1

# Kubernetes Metadata (populated by Kubernetes downward API)
KUBE_NODE_NAME=k8s-worker-1
KUBE_POD_NAME=dataforge-api-deployment-hash
KUBE_POD_NAMESPACE=dataforge
KUBE_POD_IP=10.0.0.10

# Feature: Due Diligence Configuration
DILIGENCE_MAX_FINDINGS_PER_PROJECT=10000
DILIGENCE_MAX_REVIEWS_PER_PROJECT=100
DILIGENCE_AUTO_ARCHIVE_DAYS=365
DILIGENCE_ENABLE_BULK_OPERATIONS=true

# Feature: Search Configuration
SEARCH_MAX_RESULTS=1000
SEARCH_MIN_SIMILARITY=0.5
SEARCH_EMBEDDING_BATCH_SIZE=50

# Database Maintenance
ENABLE_AUTO_VACUUM=true
ENABLE_ANALYZE=true
MAINTENANCE_WINDOW_HOUR=2  # 2 AM UTC
MAINTENANCE_WINDOW_DAY=0   # Sunday

# Backup and Recovery
DB_BACKUP_COMPRESSION=gzip
DB_BACKUP_DESTINATION=s3://dataforge-backups/
DB_BACKUP_ENABLE_ENCRYPTION=true

# Cluster Configuration (if multi-node)
CLUSTER_MODE=standalone  # Options: standalone, cluster
CLUSTER_NODES=dataforge-api-0,dataforge-api-1,dataforge-api-2
CLUSTER_REPLICATION_FACTOR=3

# Deprecated (kept for backward compatibility)
# These will be removed in future versions
LEGACY_DATABASE_URL=${DATABASE_URL}
